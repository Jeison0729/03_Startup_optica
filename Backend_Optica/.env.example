# ── NOMBRE DEL PROYECTO ────────────────────────────────
SPRING_APPLICATION_NAME=Startup Optica

# ── BASE DE DATOS (LOCAL) ──────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bd_optica
SPRING_DATASOURCE_USERNAME=tu_usuario_postgres
SPRING_DATASOURCE_PASSWORD=tu_contraseña_postgres

# ── JWT ────────────────────────────────────────────────
# El secret debe ser una cadena larga y aleatoria en Base64.
# Mínimo recomendado: 64 bytes (512 bits) para HS512.
#
# Cómo generarlo:
#   Linux / Mac:
#     openssl rand -base64 64
#
#   Windows (PowerShell):
#     [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Max 256 }))
#
#   Online (solo para pruebas, no usar en producción):
#     https://generate-random.org/encryption-key-generator
#
# Pega el resultado completo en una sola línea, sin espacios ni saltos.
JWT_SECRET=tu_clave_secreta_base64

# ── CORREO (Gmail SMTP) ────────────────────────────────
# Requiere una contraseña de aplicación de Google, NO la contraseña normal de Gmail.
# Cómo generarla:
#   1. Ir a https://myaccount.google.com/security
#   2. Activar verificación en dos pasos (requerido)
#   3. Buscar "Contraseñas de aplicaciones"
#   4. Crear una nueva → seleccionar "Correo" y "Otro (nombre personalizado)"
#   5. Google genera una clave de 16 caracteres con espacios — pégala tal cual
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── BASE DE DATOS (PRODUCCIÓN) ─────────────────────────
# Rellenar solo al desplegar en producción, dejar vacío en desarrollo local.
# Aiven provee estos datos al crear el servicio PostgreSQL:
#   Panel → tu servicio → "Connection information" → URI o campos separados
AIVEN_DB_URL=jdbc:postgresql://tu-host.aivencloud.com:puerto/bd_optica?sslmode=require
AIVEN_DB_USER=tu_usuario_aiven
AIVEN_DB_PASSWORD=tu_contraseña_aiven
